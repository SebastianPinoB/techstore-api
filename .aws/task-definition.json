{
  "family": "techstore-api",
  "taskRoleArn": "arn:aws:iam::989804099124:role/LabRole",
  "executionRoleArn": "arn:aws:iam::989804099124:role/LabRole",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "techstore-api",
      "image": "989804099124.dkr.ecr.us-east-1.amazonaws.com/techstore-api:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "default"
        },
        {
          "name": "AWS_SQS_QUEUE_URL",
          "value": "https://sqs.us-east-1.amazonaws.com/989804099124/techstore-audit-queue"
        },
        {
          "name": "SPRING_DATASOURCE_URL",
          "value": "jdbc:postgresql://techstore-db.ccb6yffmnmq5.us-east-1.rds.amazonaws.com:5432/postgres"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "value": "postgres"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "value": "techstore-db"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/techstore-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512"
}